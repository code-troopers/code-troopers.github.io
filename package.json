{
  "name": "one-click-hugo-cms",
  "version": "1.0.0",
  "description": "Hugo template with Decap CMS ",
  "repository": "decaporg/one-click-hugo-cms",
  "main": "index.js",
  "scripts": {
    "lint": "eslint src cypress",
    "start": "run-p start:**",
    "start:hugo": "hugo -d ../dist -s site -w --logLevel debug",
    "start:webpack": "webpack-dev-server --config webpack.dev.js --hot",
    "preview": "run-p preview:**",
    "preview:hugo": "npm run start:hugo -- -D -F",
    "preview:webpack": "npm run start:webpack",
    "prebuild": "rimraf dist",
    "build": "npm run build:webpack && npm run build:hugo",
    "build:preview": "npm run build:webpack && npm run build:hugo:preview",
    "build:hugo": "hugo -d ../dist -s site --logLevel debug",
    "build:hugo:preview": "npm run build:hugo -- -D -F",
    "build:webpack": "cross-env NODE_ENV=production webpack --config webpack.prod.js",
    "cypress:open": "cypress open --e2e",
    "cypress:run": "cypress run --e2e"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/eslint-parser": "^7.28.4",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.28.3",
    "@babel/register": "^7.28.3",
    "assets-webpack-plugin": "^7.1.1",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "eslint": "^9.37.0",
    "eslint-plugin-cypress": "^5.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "exports-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.4",
    "hugo-bin": "^0.148.0",
    "hugo-extended": "^0.151.0",
    "imports-loader": "^5.0.0",
    "mini-css-extract-plugin": "^2.9.4",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-custom-media": "^11.0.6",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.0",
    "postcss-preset-env": "^10.4.0",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@babel/preset-react": "^7.27.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sveltia/cms": "^0.117.0",
    "buffer": "^6.0.3",
    "cypress": "^15.4.0",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "https-browserify": "^1.0.0",
    "ignore-loader": "^0.1.2",
    "immutable": "^5.1.4",
    "lightbox2": "^2.11.5",
    "netlify-plugin-cypress": "^2.2.1",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "to-string-loader": "^1.2.0",
    "url": "^0.11.4"
  }
}
